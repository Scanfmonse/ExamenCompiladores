        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "\n",
        "# 1. Cargar el dataset original\n",
        "# Asegúrate de que el archivo CSV esté en el entorno de Colab\n",
        "df = pd.read_csv('dataset_liga_mx_jornadas_13_14_15_base.csv')\n",
        "\n",
        "# 2. Selección de features y Entrenamiento del Random Forest con datos de J15\n",
        "features = ['diff_puntos', 'diff_racha', 'diff_posicion']\n",
        "X = df[features]\n",
        "y = df['resultado']\n",
        "\n",
        "rf = RandomForestClassifier(n_estimators=300, max_depth=5, random_state=42)\n",
        "rf.fit(X, y)\n",
        "\n",
        "# 3. Calcular estadísticas actualizadas para la Jornada 16\n",
        "equipos = {}\n",
        "for i, row in df.iterrows():\n",
        "    loc = row['equipo_local']\n",
        "    vis = row['equipo_visita']\n",
        "    res = row['resultado'] # 0: Gana visita, 1: Empate, 2: Gana local\n",
        "\n",
        "    p_l = row['local_puntos']\n",
        "    p_v = row['visita_puntos']\n",
        "    r_l = row['local_racha']\n",
        "    r_v = row['visita_racha']\n",
        "\n",
        "    # Actualizar puntos y racha según el resultado del partido\n",
        "    if res == 2: # Gana local\n",
        "        equipos[loc] = {'pts': p_l + 3, 'racha': r_l + 3, 'old_pos': row['local_posicion']}\n",
        "        equipos[vis] = {'pts': p_v, 'racha': r_v, 'old_pos': row['visita_posicion']}\n",
        "    elif res == 1: # Empate\n",
        "        equipos[loc] = {'pts': p_l + 1, 'racha': r_l + 1, 'old_pos': row['local_posicion']}\n",
        "        equipos[vis] = {'pts': p_v + 1, 'racha': r_v + 1, 'old_pos': row['visita_posicion']}\n",
        "    else: # Gana visita\n",
        "        equipos[loc] = {'pts': p_l, 'racha': r_l, 'old_pos': row['local_posicion']}\n",
        "        equipos[vis] = {'pts': p_v + 3, 'racha': r_v + 3, 'old_pos': row['visita_posicion']}\n",
        "\n",
        "# Ordenar equipos por puntos (descendente) para obtener las nuevas posiciones de la tabla\n",
        "equipos_ordenados = sorted(equipos.items(), key=lambda x: (-x[1]['pts'], x[1]['old_pos']))\n",
        "for rank, (equipo, stats) in enumerate(equipos_ordenados, start=1):\n",
        "    equipos[equipo]['pos'] = rank\n",
        "\n",
        "# 4. Definir los partidos del cuestionario para la Jornada 16\n",
        "partidos_j16 = [\n",
        "    ('Querétaro','Cruz Azul'),\n",
        "    ('Pumas', 'FC Juárez'),\n",
        "    ('Monterrey', 'Puebla'),\n",
        "    ('León', 'América'),\n",
        "    ('Atlas', 'Tigres'),\n",
        "    ('Atlético San Luis', 'Santos'),\n",
        "    ('Mazatlán', 'Toluca'),\n",
        "    ('Necaxa', 'Chivas'),\n",
        "    ('Tijuana', 'Pachuca')\n",
        "]\n",
        "\n",
        "# 5. Realizar predicciones\n",
        "print(\"PREDICCIONES JORNADA 16\\n\")\n",
        "for loc, vis in partidos_j16:\n",
        "    # Extraer las estadísticas calculadas para cada equipo\n",
        "    t_loc = equipos[loc]\n",
        "    t_vis = equipos[vis]\n",
        "\n",
        "    # Calcular las diferencias (features) que espera el modelo\n",
        "    diff_puntos = t_loc['pts'] - t_vis['pts']\n",
        "    diff_racha = t_loc['racha'] - t_vis['racha']\n",
        "    diff_posicion = t_loc['pos'] - t_vis['pos']\n",
        "\n",
        "    # Crear DataFrame con el mismo formato que el de entrenamiento\n",
        "    X_pred = pd.DataFrame([[diff_puntos, diff_racha, diff_posicion]], columns=features)\n",
        "\n",
        "    # Predecir\n",
        "    pred = rf.predict(X_pred)[0]\n",
        "\n",
        "    # Formatear la salida del resultado\n",
        "    if pred == 0:\n",
        "        res_str = 'Gana visitante'\n",
        "    elif pred == 1:\n",
        "        res_str = 'Empatan'\n",
        "    else:\n",
        "        res_str = 'Gana local'\n",
        "\n",
        "    print(f\"{loc} vs {vis}\")\n",
        "    print(f\"Predicción: {res_str}\\n\")"
